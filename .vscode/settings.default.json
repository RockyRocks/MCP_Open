{
// Configure glob patterns for excluding files and folders.
"files.exclude": {
        "**/.git": true,
        "**/tmp/": true,
        "**/tools/": true,
        "**/bin/": true,
        "**/extern/": true,
        "private/": true,
        "**/anycpu/": true,
        ".teamcity/": true,
        "**/*.csproj.user": true,
        "**/*.log": true,
        "**/*.sln.DotSettings": true,
        "**/*.pdb": true,
        "**/*.dll": true,
        "**/*.exe": true,
        "**/*.bff": true,
        "**/*.vcxproj.filters": true,
        "**/*.vcxproj": true,
        "**/*.sln": true,
        "**/*.csproj": true
    },
    "search.exclude": {
        "**/*.png": true
    },
        
    // Configure file associations to languages (e.g. "*.extension": "html").
    // These have precedence over the default associations of the languages
    // installed.
    "files.associations": {
        "*.sharpmake": "csharp",
        "*.DotSettings": "xml",
        "*.editorconfig": "ini",
        ".p4ignore": "shellscript",
        "*.json": "jsonc"
    },
        
    // Don't ignore extension recommendations.
    "extensions.ignoreRecommendations": false,

    // Controls how the editor should render whitespace characters,
    // possibilities are 'none', 'boundary', and 'all'. The 'boundary' option
    // does not render single spaces between words.
    "editor.renderWhitespace": "boundary",
    "editor.guides.indentation": true,

    // Controls how lines should wrap. Can be:
    //  - 'off' (disable wrapping),
    //  - 'on' (viewport wrapping),
    //  - 'wordWrapColumn' (wrap at `editor.wordWrapColumn`) or
    //  - 'bounded' (wrap at minimum of viewport and `editor.wordWrapColumn`).
    "editor.wordWrap": "off",

    // Format a file on save. A formatter must be available, the file must not
    // be auto-saved, and editor must not be shutting down.
    // Disabled to prevent unnecessary conflicts when someone forgot to format
    // code properly.
    "editor.formatOnSave": false,
        
    // Columns at which to show vertical rulers.
    "editor.rulers": [
        80,
        100
    ],

    // Markdown-specific settings.
    "[markdown]": {
        // Markdown files have less formatting issues when lines are not cut.
        "editor.wordWrap": "on",
        "editor.rulers": []
    },

    "[cpp]": {
        "editor.rulers": [110]
    }
}
